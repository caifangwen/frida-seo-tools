{
  "Huahao Components": {
    "prefix": "hh",
    "body": [
      "<div class=\"hh-post\">",
      "$0",
      "</div>"
    ],
    "description": "Huahao Post Wrapper"
  },
  "Huahao Hero": {
    "prefix": "hhero",
    "body": [
      "<div class=\"hh-hero\">",
      "  <span class=\"hh-hero-eyebrow\">${1:Guide · 2026}</span>",
      "  <h1>${2:Title}</h1>",
      "  <p class=\"hh-hero-sub\">${3:Subtitle text...}</p>",
      "  <div class=\"hh-hero-stats\">",
      "    <div><span class=\"hh-hero-stat-num\">${4:100+}</span><span class=\"hh-hero-stat-label\">${5:Label}</span></div>",
      "  </div>",
      "</div>"
    ],
    "description": "Huahao Hero Banner"
  },
  "Huahao Section Header": {
    "prefix": "hhsec",
    "body": [
      "<div class=\"hh-section-header\">",
      "  <div class=\"hh-section-num\">${1:01}</div>",
      "  <div>",
      "    <span class=\"hh-section-tag\">${2:Tag}</span>",
      "    <h2 class=\"hh-section-title\">${3:Section Title}</h2>",
      "  </div>",
      "</div>"
    ],
    "description": "Huahao Section Header"
  },
  "Huahao Box Info": {
    "prefix": "hhboxi",
    "body": [
      "<div class=\"hh-box-info\">",
      "  <p><span class=\"hh-box-icon\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><line x1=\"12\" y1=\"16\" x2=\"12\" y2=\"12\"></line><line x1=\"12\" y1=\"8\" x2=\"12.01\" y2=\"8\"></line></svg></span>${1:Info text...}</p>",
      "</div>"
    ],
    "description": "Huahao Info Box"
  },
  "Huahao Box Tip": {
    "prefix": "hhboxt",
    "body": [
      "<div class=\"hh-box-tip\">",
      "  <p><span class=\"hh-box-icon\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M12 2a7 7 0 017 7c0 2.38-1.19 4.47-3 5.74V17a2 2 0 01-2 2H10a2 2 0 01-2-2v-2.26C6.19 13.47 5 11.38 5 9a7 7 0 017-7z\"></path><path d=\"M9 21h6\"></path></svg></span><strong>Pro tip:</strong> ${1:Tip content...}</p>",
      "</div>"
    ],
    "description": "Huahao Tip Box"
  },
  "Huahao Box Warn": {
    "prefix": "hhboxw",
    "body": [
      "<div class=\"hh-box-warn\">",
      "  <p><span class=\"hh-box-icon\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z\"></path><line x1=\"12\" y1=\"9\" x2=\"12\" y2=\"13\"></line><line x1=\"12\" y1=\"17\" x2=\"12.01\" y2=\"17\"></line></svg></span><strong>Warning:</strong> ${1:Warning content...}</p>",
      "</div>"
    ],
    "description": "Huahao Warning Box"
  },
  "Huahao Checklist": {
    "prefix": "hhcheck",
    "body": [
      "<ul class=\"hh-checklist\">",
      "  <li>${1:Item 1}</li>",
      "  <li>${2:Item 2}</li>",
      "  <li>${3:Item 3}</li>",
      "</ul>"
    ],
    "description": "Huahao Checklist"
  },
  "Huahao Table": {
    "prefix": "hhtable",
    "body": [
      "<div class=\"hh-table-wrap\">",
      "  <table class=\"hh-table\">",
      "    <thead>",
      "      <tr>",
      "        <th>${1:Header 1}</th>",
      "        <th>${2:Header 2}</th>",
      "      </tr>",
      "    </thead>",
      "    <tbody>",
      "      <tr>",
      "        <td>${3:Data 1}</td>",
      "        <td>${4:Data 2}</td>",
      "      </tr>",
      "    </tbody>",
      "  </table>",
      "</div>"
    ],
    "description": "Huahao Table"
  },
  "Huahao FAQ": {
    "prefix": "hhfaq",
    "body": [
      "<div class=\"hh-faq\">",
      "  <details class=\"hh-faq-item\">",
      "    <summary class=\"hh-faq-q\">${1:Question?}</summary>",
      "    <div class=\"hh-faq-a\">",
      "      <p>${2:Answer...}</p>",
      "    </div>",
      "  </details>",
      "</div>"
    ],
    "description": "Huahao FAQ Item"
  },
  "Huahao CTA": {
    "prefix": "hhcta",
    "body": [
      "<div class=\"hh-cta\">",
      "  <span class=\"hh-cta-tag\">${1:Call to Action}</span>",
      "  <h2>${2:CTA Title}</h2>",
      "  <p>${3:CTA description...}</p>",
      "  <div class=\"hh-cta-btns\">",
      "    <a href=\"${4:/contact}\" class=\"hh-btn-primary\">${5:Get Started}</a>",
      "    <a href=\"${6:#}\" class=\"hh-btn-outline\">${7:Learn More}</a>",
      "  </div>",
      "</div>"
    ],
    "description": "Huahao CTA Banner"
  },
  "Huahao Cards": {
    "prefix": "hhcards",
    "body": [
      "<div class=\"hh-cards\">",
      "  <div class=\"hh-card\">",
      "    <span class=\"hh-card-icon\">",
      "      <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\"><path d=\"M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z\"></path><polyline points=\"3.27 6.96 12 12.01 20.73 6.96\"></polyline><line x1=\"12\" y1=\"22.08\" x2=\"12\" y2=\"12\"></line></svg>",
      "    </span>",
      "    <h4>${1:Card Title}</h4>",
      "    <p>${2:Card description...}</p>",
      "  </div>",
      "</div>"
    ],
    "description": "Huahao Cards Grid"
  },
  "Huahao Steps": {
    "prefix": "hhsteps",
    "body": [
      "<div class=\"hh-steps\">",
      "  <div class=\"hh-step\">",
      "    <div class=\"hh-step-n\">${1:01}</div>",
      "    <h4>${2:Step Title}</h4>",
      "    <p>${3:Step description...}</p>",
      "  </div>",
      "</div>"
    ],
    "description": "Huahao Steps"
  },
  "Huahao Flow": {
    "prefix": "hhflow",
    "body": [
      "<div class=\"hh-flow\">",
      "  <div class=\"hh-flow-step\">",
      "    <div class=\"hh-flow-dot\">${1:1}</div>",
      "    <div class=\"hh-flow-body\">",
      "      <span class=\"hh-flow-tag\">${2:Tag}</span>",
      "      <strong>${3:Title}</strong>",
      "      <p>${4:Description...}</p>",
      "    </div>",
      "  </div>",
      "</div>"
    ],
    "description": "Huahao Flowchart"
  },
  "Huahao Split": {
    "prefix": "hhsplit",
    "body": [
      "<div class=\"hh-split\">",
      "  <div class=\"hh-split-col\">",
      "    <h4>${1:Column 1 Title}</h4>",
      "    <ul class=\"hh-checklist\">",
      "      <li>${2:Item 1}</li>",
      "      <li>${3:Item 2}</li>",
      "    </ul>",
      "  </div>",
      "  <div class=\"hh-split-col\">",
      "    <h4>${4:Column 2 Title}</h4>",
      "    <ul class=\"hh-checklist\">",
      "      <li>${5:Item 1}</li>",
      "      <li>${6:Item 2}</li>",
      "    </ul>",
      "  </div>",
      "</div>"
    ],
    "description": "Huahao Split Columns"
  },
  "Huahao Stats": {
    "prefix": "hhstats",
    "body": [
      "<div class=\"hh-stats\">",
      "  <div class=\"hh-stat\">",
      "    <span class=\"hh-stat-num\">${1:100+}</span>",
      "    <span class=\"hh-stat-label\">${2:Label}</span>",
      "  </div>",
      "</div>"
    ],
    "description": "Huahao Stats Grid"
  },
  "Huahao Bars": {
    "prefix": "hhbars",
    "body": [
      "<div class=\"hh-bars\">",
      "  <span class=\"hh-bars-title\">${1:Chart Title}</span>",
      "  <div class=\"hh-bar-row\">",
      "    <span class=\"hh-bar-label\">${2:Label}</span>",
      "    <div class=\"hh-bar-track\"><div class=\"hh-bar-fill\" style=\"width:${3:80}%\"></div></div>",
      "    <span class=\"hh-bar-val\">${4:Value}</span>",
      "  </div>",
      "</div>"
    ],
    "description": "Huahao Bar Chart"
  },
  "Huahao Specs": {
    "prefix": "hhspecs",
    "body": [
      "<div class=\"hh-specs\">",
      "  <div class=\"hh-spec-card\">",
      "    <div class=\"hh-spec-head\">${1:Spec Name}</div>",
      "    <div class=\"hh-spec-body\">",
      "      <div class=\"hh-spec-val\">${2:Value}</div>",
      "      <div class=\"hh-spec-note\">${3:Note}</div>",
      "    </div>",
      "  </div>",
      "</div>"
    ],
    "description": "Huahao Specs Cards"
  },
  "Huahao Verdict": {
    "prefix": "hhverdict",
    "body": [
      "<div class=\"hh-verdict\">",
      "  <span class=\"hh-verdict-title\">${1:Summary}</span>",
      "  <div class=\"hh-verdict-row\">",
      "    <span class=\"hh-verdict-key\">${2:Key}</span>",
      "    <span class=\"hh-verdict-val\">${3:Value}</span>",
      "  </div>",
      "</div>"
    ],
    "description": "Huahao Verdict Table"
  },
  "Huahao Timeline": {
    "prefix": "hhtimeline",
    "body": [
      "<div class=\"hh-timeline\">",
      "  <div class=\"hh-timeline-item\">",
      "    <div class=\"hh-timeline-dot\"></div>",
      "    <div class=\"hh-timeline-label\">${1:Time}</div>",
      "    <div class=\"hh-timeline-title\">${2:Event}</div>",
      "  </div>",
      "</div>"
    ],
    "description": "Huahao Timeline"
  }
}
